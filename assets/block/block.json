{
  "apiVersion": 2,
  "name": "andw-news/latest-posts",
  "title": "andW News",
  "description": "新着投稿の一覧を表示します。リンク先の変更やタブ切り替えに対応。",
  "category": "widgets",
  "icon": "megaphone",
  "keywords": ["news", "list", "andw", "お知らせ"],
  "supports": {
    "html": false,
    "align": ["wide", "full"]
  },
  "attributes": {
    "perPage": {
      "type": "number",
      "default": 10
    },
    "categories": {
      "type": "array",
      "default": []
    },
    "showCategories": {
      "type": "boolean",
      "default": true
    },
    "showTabs": {
      "type": "boolean",
      "default": false
    },
    "pinnedFirst": {
      "type": "boolean",
      "default": false
    }
  },
  "textdomain": "andw-news",
  "editorScript": "andw-news-block-editor"
}
